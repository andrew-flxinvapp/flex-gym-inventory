<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Replace 'development' with 'production' for App Store builds when you
	     upload a production APNs key/certificate. Enabling this file in the Xcode
	     target (Signing & Capabilities → + Capability → Push Notifications)
	     is required to receive remote notifications. -->
	<key>aps-environment</key>
	<string>development</string>
</dict>
</plist>
